# ---------------------------------------------------------------------------
# home-os — environment variables
# Copy to .env and fill in real values for local dev. Never commit .env.
# ---------------------------------------------------------------------------

# Where persistent data lives. In dev this is ./.data, on the Pi this might
# be /mnt/data (USB-SSD) or /srv/home-os/data (SD card). This is the ONLY
# place the data root is defined — api + litestream + scripts all read it.
HOME_OS_DATA_DIR=./.data

# API server
HOME_OS_API_HOST=127.0.0.1
HOME_OS_API_PORT=4000
HOME_OS_WEB_ORIGIN=http://localhost:5173

# Session / cookie signing (32+ random bytes, base64). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
HOME_OS_SESSION_SECRET=change-me-please-change-me-please-change-me-please

# Google OAuth (set up in Google Cloud Console; tailnet hostname as redirect)
HOME_OS_GOOGLE_CLIENT_ID=
HOME_OS_GOOGLE_CLIENT_SECRET=
HOME_OS_GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# Comma-separated allowlist of Google emails permitted to sign in.
HOME_OS_ALLOWED_EMAILS=

# AI provider: "disabled" | "copilot" | "openai" | "anthropic"
HOME_OS_AI_PROVIDER=disabled
HOME_OS_AI_API_KEY=

# ---------------------------------------------------------------------------
# Phase 10 — Deployment
# ---------------------------------------------------------------------------

# In production (docker-compose) the api container sets this to "false" so
# migrations only run via the one-shot `migrate` service (which takes a
# snapshot + checks for destructive SQL first).
HOME_OS_AUTO_MIGRATE=true

# Set to 1 to allow pending DROP TABLE / DROP COLUMN / recreate-table
# migrations through the safety gate. Leave unset unless you've confirmed
# the data-loss implications and have a fresh backup.
HOME_OS_ALLOW_DESTRUCTIVE_MIGRATIONS=

# Tailnet hostname Caddy serves on. Typically <pi>.<tailnet>.ts.net.
HOME_OS_TAILNET_HOST=home-os.local

# Published container image references (used by docker-compose).
HOME_OS_API_IMAGE=ghcr.io/chasehelton/home-os-api:latest
HOME_OS_WEB_IMAGE=ghcr.io/chasehelton/home-os-web:latest

# Litestream replica (S3 or B2 URL). Leave empty to disable continuous backup.
LITESTREAM_REPLICA_URL=
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=
LITESTREAM_REGION=
