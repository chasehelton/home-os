# Internal static-SPA server (used by the `web` container).
# The outer Caddy reverse-proxies here for all non-api/auth/health paths.
{
	admin off
}

:8080 {
	root * /srv/www
	encode zstd gzip
	# SPA fallback: any unknown path serves index.html.
	try_files {path} /index.html
	file_server
	# Long-cache hashed assets; never cache the index.
	@assets path *.js *.css *.woff *.woff2 *.png *.jpg *.svg *.webp
	header @assets Cache-Control "public, max-age=31536000, immutable"
	header /index.html Cache-Control "no-cache"
}
